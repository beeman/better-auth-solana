{
  "bugs": {
    "url": "https://github.com/beeman/better-auth-solana/issues"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "description": "Better Auth plugin for Solana sign-in.",
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@changesets/cli": "2.30.0",
    "@intellectronica/ruler": "0.3.38",
    "@solana/kit": "6.8.0",
    "@types/bun": "1.3.12",
    "better-auth": "1.5.4",
    "lefthook": "1.7.11",
    "pkg-pr-new": "0.0.62",
    "publint": "0.3.16",
    "syncpack": "13.0.4",
    "tsdown": "0.20.3",
    "typescript": "6.0.2"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.mts",
        "default": "./dist/client.mjs"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    },
    "./schema": {
      "import": {
        "types": "./dist/schema.d.mts",
        "default": "./dist/schema.mjs"
      },
      "require": {
        "types": "./dist/schema.d.cts",
        "default": "./dist/schema.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/beeman/better-auth-solana",
  "keywords": [
    "authentication",
    "better-auth",
    "siws",
    "solana",
    "wallet"
  ],
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "name": "better-auth-solana",
  "peerDependencies": {
    "@solana/kit": "^6.8.0",
    "better-auth": "^1.5.0",
    "typescript": "^5 || ^6"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeman/better-auth-solana.git"
  },
  "scripts": {
    "build": "tsdown",
    "changeset": "changeset",
    "check-types": "tsc -b --noEmit",
    "ci": "bun run --sequential build syncpack:lint lint check-types test",
    "lint": "biome check --error-on-warnings",
    "lint:fix": "biome check --error-on-warnings --write",
    "prepare": "lefthook install",
    "release": "changeset publish",
    "ruler:apply": "ruler apply --local-only",
    "syncpack:lint": "syncpack lint-semver-ranges --config syncpack.config.ts --source package.json --types dev",
    "test": "bun test ./test",
    "test:watch": "bun test --watch ./test",
    "version": "changeset version && bun lint:fix"
  },
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "0.0.0"
}
